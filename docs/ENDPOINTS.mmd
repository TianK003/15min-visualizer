flowchart LR
  %% ========= Nodes =========
  Client["Client (Browser)<br/>Next.js 14 / MapLibre / deck.gl"]
  Next["Next.js Server<br/>(Vercel runtime)"]
  Valhalla["Valhalla<br/>Railway :8002"]
  Supa["Supabase<br/>Postgres + PostGIS + Storage"]
  OFM["OpenFreeMap<br/>tiles.openfreemap.org"]
  Photon["Photon<br/>photon.komoot.io"]
  Nominatim["Nominatim<br/>nominatim.openstreetmap.org"]
  OR["OpenRouter<br/>openrouter.ai -> minimax/minimax-01"]
  EProstor["e-prostor (GURS/MNVP)<br/>ipi.eprostor.gov.si"]
  ARSO["ARSO GeoServer<br/>gis.arso.gov.si"]
  Geofabrik["Geofabrik<br/>download.geofabrik.de"]
  GURSmirror["GURS mirror<br/>github.com/stefanb/gurs-rpe"]
  Kontur["Kontur (HDX)<br/>data.humdata.org"]
  SURS["SURS SiStat<br/>pxweb.stat.si"]
  ETL["ETL Pipeline<br/>(offline, Python)"]
  Static["/public/data/*<br/>(static JSON shipped w/ build)"]

  %% ========= Client -> external/internal =========
  Client -- "GET /styles/positron, /styles/dark-matter<br/><i>vector basemap tiles</i>" --> OFM
  Client -- "GET /api/?q=&lt;query&gt;&amp;bbox=SI&amp;limit=6<br/><i>address suggestions</i>" --> Photon
  Client -- "GET /search?q=..&amp;countrycodes=si<br/><i>fallback geocode</i>" --> Nominatim

  Client -- "GET /storage/v1/object/public/cells/cell_scores_lite.json<br/>GET .../cells/cell_demand_lite.json<br/>GET .../overlays/obcine_scored.geojson<br/>GET .../overlays/zavarovana_si.geojson" --> Supa
  Client -- "POST /rest/v1/rpc/amenities_for_point {p_lat,p_lng,p_mode}<br/>GET /rest/v1/cell_scores?h3=eq.X<br/>GET /rest/v1/obcine?naziv=eq.X<br/>POST /rest/v1/rpc/llm_search_cells {filter_spec,p_limit}<br/>+ apikey/Bearer anon" --> Supa

  Client -- "GET wfs-si-mnvp-pa/wfs (OPN zones NRP_OPN, CQL BBOX)<br/>GET wfs-si-gurs-kn/wfs (STAVBE_OBRIS, BBOX)" --> EProstor

  Client -- "GET /data/cell_cat_scores.json<br/>GET /data/building_suggestions.json<br/>GET /data/obcine_demographics.json<br/>GET /data/fro.geojson" --> Static

  Client -- "POST /api/llm {kind, query|h3+score+walk_min}<br/>POST /api/valhalla/{isochrone|route|sources_to_targets}" --> Next

  %% ========= Next.js server -> upstream =========
  Next -- "POST /isochrone {locations,costing,contours}<br/>POST /route {locations,costing}<br/>POST /sources_to_targets {sources,targets,costing}<br/>(proxy: avoids CORS preflight)" --> Valhalla
  Next -- "POST /api/v1/chat/completions<br/>{model: minimax/minimax-01, messages, response_format: json_object}" --> OR
  Next -- "GET /api/?q=&lt;target_town&gt;&amp;limit=1<br/>lat/lng for H3 disk" --> Photon
  Next -- "POST /rest/v1/rpc/llm_search_cells {filter_spec,p_limit}" --> Supa

  %% ========= ETL (offline, build-time) =========
  Geofabrik   -- "curl slovenia-latest.osm.pbf (~300 MB)" --> ETL
  GURSmirror  -- "curl OB.geojson (212 obcine)" --> ETL
  ARSO        -- "WFS GetFeature ZOS_ZO_PLG_DRZ + ZOS_N2K_PLG" --> ETL
  Kontur      -- "kontur_population_SI.gpkg" --> ETL
  SURS        -- "PxWeb /api/v1/sl/Data (age shares, indicators)" --> ETL
  ETL -- "POST /isochrone x 112,866 (amenity bake)" --> Valhalla
  ETL -- "psql + storage upload<br/>cell_scores, cell_amenities, obcine, overlays/*" --> Supa
  ETL -- "writes cell_scores_lite, cell_demand_lite,<br/>obcine_scored, obcine_demographics,<br/>cell_cat_scores, building_suggestions, fro" --> Static

  classDef client fill:#dbeafe,stroke:#1e40af,color:#0f172a;
  classDef server fill:#fef3c7,stroke:#a16207,color:#0f172a;
  classDef datastore fill:#dcfce7,stroke:#15803d,color:#0f172a;
  classDef external fill:#fce7f3,stroke:#be185d,color:#0f172a;
  classDef etl fill:#e9d5ff,stroke:#7c3aed,color:#0f172a;

  class Client client;
  class Next,Valhalla server;
  class Supa,Static datastore;
  class OFM,Photon,Nominatim,OR,EProstor,ARSO,Geofabrik,GURSmirror,Kontur,SURS external;
  class ETL etl;
